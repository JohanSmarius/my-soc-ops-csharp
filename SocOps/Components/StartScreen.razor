<div class="hero-root">
    <div class="hero-scenery" aria-hidden="true">
        <div class="hero-treeline"></div>
        <div class="hero-mist"></div>
    </div>

    <div class="hero-content">
        <div class="hero-ornament hero-child" aria-hidden="true">◆ ◆ ◆</div>
        <p class="hero-kicker hero-child">Welcome to the Lodge</p>
        <h1 class="hero-title hero-child">Soc&nbsp;Ops</h1>
        <p class="hero-sub hero-child">Social Bingo &middot; Find&nbsp;Your&nbsp;People</p>
        <ul class="hero-rules hero-child" aria-label="How to play">
            <li>Find people who match the squares</li>
            <li>Tap a square when you find a match</li>
            <li>Get five in a row to win</li>
        </ul>
        <button
            @onclick="OnStart"
            class="hero-cta hero-child">
            Enter the Lodge
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
