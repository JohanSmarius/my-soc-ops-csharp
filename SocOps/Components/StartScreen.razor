<div class="landing-root">
    <div class="landing-ambient" aria-hidden="true"></div>

    <div class="landing-frame">
        <p class="cabin-kicker landing-kicker cabin-reveal-1">Welcome to the Lodge</p>

        <div class="landing-hero cabin-reveal-2">
            <h1 class="landing-title cabin-title">
                <span class="landing-title-line">Soc</span><span class="landing-title-line">Ops</span>
            </h1>
            <div class="landing-ornament" aria-hidden="true"></div>
            <p class="landing-subtitle">Social Bingo</p>
        </div>

        <div class="cabin-reveal-3">
            <div class="cabin-card landing-card p-6 mb-6">
                <h2 class="landing-card-heading font-semibold text-cabin-ink mb-3">How to play</h2>
                <ul class="text-left text-cabin-muted text-sm space-y-2">
                    <li>• Find people who match the questions</li>
                    <li>• Tap a square when you find a match</li>
                    <li>• Get 5 in a row to win!</li>
                </ul>
            </div>

            <button
                @onclick="OnStart"
                class="cabin-cta landing-cta py-4 px-8 text-lg">
                Start Game
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
