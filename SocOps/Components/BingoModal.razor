<div class="cabin-modal-backdrop">
    <div class="cabin-modal">
        <div class="text-5xl mb-4">🎉</div>
        <h2 class="text-3xl font-bold cabin-modal-title mb-2 cabin-title">BINGO!</h2>
        <p class="text-cabin-muted mb-6">You completed a line!</p>

        <button
            @onclick="OnDismiss"
            class="cabin-cta py-3 px-6">
            Keep Playing
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
