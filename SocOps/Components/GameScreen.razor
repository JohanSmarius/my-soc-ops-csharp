@using SocOps.Models

<div class="flex flex-col min-h-full p-3">
    <header class="flex items-center justify-between p-3 cabin-card mb-3">
        <button
            @onclick="OnReset"
            class="cabin-ghost text-sm px-3 py-1.5">
            ← Back
        </button>
        <h1 class="font-bold text-gray-900 cabin-title">Soc Ops</h1>
        <div class="w-16"></div>
    </header>

    <p class="text-center text-cabin-muted text-sm px-4 py-2 mb-3">
        Tap a square when you find someone who matches it.
    </p>

    @if (HasBingo)
    {
        <div class="cabin-status text-center py-2 px-3 font-semibold text-sm mb-3">
            🎉 BINGO! You got a line!
        </div>
    }

    <div class="flex-1 flex items-center justify-center p-1">
        <BingoBoard
            Board="@Board"
            WinningSquareIds="@WinningSquareIds"
            OnSquareClick="@OnSquareClick" />
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
